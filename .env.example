NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: used by future server-only Postgres/Supabase service tasks.
SUPABASE_SERVICE_ROLE_KEY=

# Commerce and accounting integrations.
# Shopify custom app credentials.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,read_inventory,read_orders,read_purchase_orders

# Amazon Selling Partner API app authorization.
AMAZON_SP_API_APPLICATION_ID=
AMAZON_SP_API_SELLER_CENTRAL_URL=https://sellercentral.amazon.com
AMAZON_SP_API_DRAFT_MODE=true

# QuickBooks Online OAuth credentials.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_SCOPES=com.intuit.quickbooks.accounting
